# Copy this file to .env and edit the values for your OpenAI-compatible endpoint.
#
# Local OpenAI-compatible server example:
RATE_OPENAI_ENDPOINT=http://127.0.0.1:6767/v1
RATE_OPENAI_API_KEY=not-needed
RATE_OPENAI_MODEL_ID=

# Optional tuning.
RATE_ANALYSIS_ENABLED=true
RATE_ANALYSIS_TEMPERATURE=0.2
RATE_ANALYSIS_MAX_TOKENS=700

# Optional extra instructions appended to PROCESS_RATE_PROMPT.md.
# RATE_EXTRA_PROMPT=Prioritize HVAC, EV charging, laundry, and dishwasher timing.
